# NextAuth（必填，才能使用 Google 登入）
# 產生方式：openssl rand -base64 32
AUTH_SECRET=
# 本機開發建議明確設定（與瀏覽器網址一致）
AUTH_URL=http://localhost:3000

# Google OAuth（Google Cloud Console → 憑證 → OAuth 2.0 用戶端）
# 授權重新導向 URI：http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 雲端同步（Vercel / Upstash Redis，與基金淨值快取可共用同一 KV）
KV_REST_API_URL=
KV_REST_API_TOKEN=
