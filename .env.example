# NextAuth（必填，才能使用 Google 登入）
# 產生方式：openssl rand -base64 32
AUTH_SECRET=
# 本機開發建議明確設定（與瀏覽器網址一致）
AUTH_URL=http://localhost:3000

# Google OAuth（Google Cloud Console → 憑證 → OAuth 2.0 用戶端）
# 授權重新導向 URI：http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 雲端同步（本機與 Vercel 必須是「同一個」Upstash 資料庫的 URL + Token）
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 若 Vercel 只提供下列名稱，可只填這組（程式會自動辨識）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# AI 版面助理（Google AI Studio 免費 Tier 可用）
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 選填；未設定時使用 gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash-lite

# AI 第一備援：Groq 免費方案
# https://console.groq.com/keys
GROQ_API_KEY=
# 選填；未設定時使用 qwen/qwen3.6-27b
GROQ_MODEL=qwen/qwen3.6-27b
